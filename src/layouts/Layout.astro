---
import '@/styles/global.css'

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="Sales Admin SaaS" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" href="/favicon.png"/>
        <title>{title}</title>
    </head>
    <body class="bg-primary font-display text-white antialiased">
        <slot />
    </body>
</html>

<style is:global>
    /* Usamos las variables definidas en @theme (--color-primary, --color-accent, etc) */
    
    .glass-nav {
        /* Usamos la variable primary con opacidad */
        background: color-mix(in srgb, var(--color-primary), transparent 20%);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }

    .glow-effect {
        /* Sombra dinámica usando el color accent */
        box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent), transparent 70%);
    }

    /* En v4 puedes usar @utility para crear clases personalizadas rápidamente */
    @utility text-glow {
        text-shadow: 0 0 30px color-mix(in srgb, var(--color-accent), transparent 50%);
    }

    @utility hero-gradient {
        background: radial-gradient(
            circle at 50% -20%, 
            color-mix(in srgb, var(--color-accent), transparent 85%) 0%, 
            var(--color-primary) 60%
        );
    }

    @utility bg-radial-at-t {
        background: radial-gradient(
            ellipse at top,
            color-mix(in srgb, var(--color-accent), transparent 85%) 0%,
            var(--color-primary) 70%
        );
    }

    html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        /* Aseguramos que el scroll sea suave */
        scroll-behavior: smooth;
    }
</style>