---
---
<section class="snap-start scroll-mt-10 px-6 py-12 min-h-screen w-full relative overflow-hidden" id="contacto">
    <!-- Fondo sutil con gradiente -->
    <div class="absolute inset-0 bg-radial-at-t opacity-20"></div>
    
    <div class="mx-auto max-w-7xl relative z-10">
        <div class="grid gap-16 lg:grid-cols-2 items-center">
        
            <div class="flex flex-col justify-center gap-6">
                <h2 class="text-4xl font-bold text-white md:text-5xl leading-tight text-glow">
                ¿Listo para transformar tu empresa?
                </h2>
                <p class="text-lg text-custom-gray max-w-md">
                Únete a más de 100 empresas que ya están optimizando su administración con nuestra plataforma.
                </p>
                
                <div class="flex flex-col gap-4 mt-4">
                    <div class="group flex items-center gap-6 ml-4 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-all duration-300">
                        <div class="p-2 rounded-lg bg-accent/20 group-hover:bg-accent/30 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
                                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                            </svg>
                        </div>
                        <span class="text-custom-gray font-medium group-hover:text-white transition-colors">fadikirbag5@gmail.com</span>
                    </div>

                    <div class="group flex items-center gap-6 ml-4 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-all duration-300">
                        <div class="p-2 rounded-lg bg-accent/20 group-hover:bg-accent/30 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
                                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                            </svg>
                        </div>
                        <span class="text-custom-gray font-medium group-hover:text-white transition-colors">+58 424-7217176</span>
                    </div>
                </div>
            </div>

            <div class="group relative rounded-3xl border border-white/20 bg-linear-to-br from-card-dark/95 via-card-dark/90 to-card-dark/80 p-8 shadow-2xl hover:shadow-accent/30 transition-all duration-500 overflow-hidden">
                <!-- Efecto de fondo animado -->
                <div class="absolute -top-24 -right-24 h-48 w-48 bg-accent/10 blur-[100px] rounded-full group-hover:bg-accent/20 transition-all duration-700"></div>
                <div class="absolute -bottom-24 -left-24 h-48 w-48 bg-tertiary/10 blur-[100px] rounded-full group-hover:bg-tertiary/20 transition-all duration-700"></div>
                
                <form action="#" class="grid gap-5 relative z-10" id="form">

                    <div class="grid gap-5 md:grid-cols-2">
                        <div class="space-y-2">
                        <label class="text-xs font-bold tracking-wider text-white/70 ml-1">Nombre Completo</label>
                        <input 
                            class="w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3.5 text-white focus:border-accent focus:bg-white/10 focus:ring-2 focus:ring-accent/50 outline-none transition-all duration-300 placeholder:text-white/30 hover:border-white/30" 
                            name="name"
                            placeholder="Nombre y apellido" 
                            type="text"
                            required
                        />
                        </div>
                        <div class="space-y-2">
                        <label class="text-xs font-bold tracking-wider text-white/70 ml-1">Correo Electrónico</label>
                        <input 
                            class="w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3.5 text-white focus:border-accent focus:bg-white/10 focus:ring-2 focus:ring-accent/50 outline-none transition-all duration-300 placeholder:text-white/30 hover:border-white/30" 
                            name="email"
                            placeholder="email@company.com" 
                            type="email"
                            required
                        />
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold tracking-wider text-white/70 ml-1">Nombre de la Empresa</label>
                        <input 
                        class="w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3.5 text-white focus:border-accent focus:bg-white/10 focus:ring-2 focus:ring-accent/50 outline-none transition-all duration-300 placeholder:text-white/30 hover:border-white/30" 
                        name="company"
                        placeholder="Solutions Inc." 
                        type="text"
                        />
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-bold tracking-wider text-white/70 ml-1">Mensaje</label>
                        <textarea 
                        class="w-full rounded-xl border border-white/20 bg-white/5 px-4 py-3.5 text-white focus:border-accent focus:bg-white/10 focus:ring-2 focus:ring-accent/50 outline-none transition-all duration-300 placeholder:text-white/30 hover:border-white/30 resize-none" 
                        name="message"
                        placeholder="¿Cómo podemos ayudarte?" 
                        rows="4"
                        required
                        ></textarea>
                    </div>

                    <button 
                        class="glow-effect flex h-14 w-full items-center justify-center rounded-xl bg-linear-to-r from-accent to-tertiary text-base font-bold text-white hover:from-accent/90 hover:to-tertiary/90 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-accent/20 cursor-pointer group-hover:shadow-accent/40" 
                        type="submit"
                    >
                        <span class="flex items-center gap-2">
                            Enviar Mensaje
                            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"></path>
                            </svg>
                        </span>
                    </button>
                </form>
            </div>

        </div>
    </div>
</section>

<script>
    const form = document.getElementById('form') as HTMLFormElement;

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);

        try {
            const response = await fetch('/api/send-email', {
                method: 'POST',
                body: formData,
            });

            if (response.ok) {
                alert('¡Mensaje enviado con éxito!');
                form.reset();
            } else {
                alert('Hubo un error al enviar el mensaje.');
            }
        } catch (error) {
            console.error(error);
        } 
    });
</script>