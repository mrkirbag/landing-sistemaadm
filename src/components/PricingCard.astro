---
interface Props {
    title: string;
    suscripcion: string;
    price: string;
    time: string;
    description: string;
    features: string[];
}

const { 
    title, 
    suscripcion,
    price,
    time, 
    description, 
    features, 
} = Astro.props;

// Configuración de WhatsApp
const phoneNumber = "584247217176";
const message = `Hola! 👋 Me interesa contratar el sistema. 

📊 *Plan Seleccionado:* ${title}
💰 *Costo:* $${price}/${time}
🚀 *Suscripción:* $${suscripcion}

¿Podrían darme más información?`;

const encodedMessage = encodeURIComponent(message);
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
---

<div class="group flex flex-col rounded-2xl border p-5 transition-all duration-300 cursor-pointer
    bg-card-dark border-white/5 
    hover:border-primary hover:shadow-[0_0_25px_rgba(150,135,237,0.15)] 
    hover:scale-105 active:scale-[0.98] z-10">

    <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-background-dark whitespace-nowrap opacity-0 translate-y-2 transition-all duration-300 group-hover:opacity-100 group-hover:-translate-y-1">
        Seleccionado
    </div>

    <div class="mb-5">
        <h3 class="text-base font-bold text-white">
            {title}
        </h3>
        
        <div class="mt-4 flex flex-col gap-0.5">
            <div class="flex items-baseline gap-1">
                <span class="text-4xl font-extrabold text-white tracking-tight">${price}</span>
                <span class="text-xs text-text-muted font-medium">/{time}</span>
            </div>

            <div class="flex items-center gap-1.5 opacity-90">
                <span class="text-sm font-bold text-custom-gray uppercase tracking-tight">+ ${suscripcion}</span>
                <span class="text-[10px] text-text-muted leading-none">pago único de activación y despliegue</span>
            </div>
        </div>

        <p class="mt-3 text-xs text-text-muted leading-snug">
            {description}
        </p>
    </div>

    <ul class="mb-6 flex flex-1 flex-col gap-2.5">
        {features.map((feature) => (
            <li class="flex items-start gap-2 text-[13px] text-text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary mt-0.5 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="#DADADA" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="leading-tight">{feature}</span>
            </li>
        ))}  
    </ul>

    <a class="flex h-10 w-full items-center justify-center rounded-lg text-sm font-bold transition-all
        border border-white/20 bg-white/5 text-white hover:scale-105 cursor-pointer active:scale-95"
    href={whatsappUrl}
    target="_blank" 
    rel="noopener noreferrer"    
    >
        Contactar
    </a>
</div>