---
interface Props {
    title: string;
    suscripcion: string;
    price: string;
    time: string;
    description: string;
    features: string[];
}

const { 
    title, 
    suscripcion,
    price,
    time, 
    description, 
    features,
} = Astro.props;

const phoneNumber = "584247217176";
const message = `Hola! 👋 Me interesa contratar el sistema. \n\n📊 *Plan Seleccionado:* ${title}\n💰 *Costo:* $${price}/${time}\n🚀 *Suscripción:* $${suscripcion}`;

const encodedMessage = encodeURIComponent(message);
const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodedMessage}`;
---

<div class="group relative flex flex-col rounded-2xl border border-white/20 bg-card-dark p-6 transition-all duration-500 max-w-sm 
    hover:border-accent/50 hover:shadow-[0_25px_60px_-15px_rgba(168,85,247,0.4)] hover:-translate-y-2
    active:border-accent/50 active:shadow-[0_25px_60px_-15px_rgba(168,85,247,0.4)] active:-translate-y-2
    touch-manipulation outline-none">
    
    <div class="mb-5">
        <h3 class="text-lg font-bold text-white tracking-tight group-hover:text-accent group-hover:text-glow group-active:text-accent group-active:text-glow transition-colors duration-300">
            {title}
        </h3>
        
        <div class="mt-4 flex flex-col gap-1">
            <div class="flex items-baseline gap-1">
                <span class="text-3xl font-black text-white tracking-tighter">${price}</span>
                <span class="text-sm text-text-muted/50 font-medium">/{time}</span>
            </div>

            <div class="flex items-center gap-2">
                <span class="text-[11px] font-bold text-white uppercase tracking-wider group-hover:text-accent group-active:text-accent transition-colors duration-300">
                    +{suscripcion} de activación
                </span>
                <span class="h-1 w-1 rounded-full bg-white/20"></span>
                <span class="text-[10px] text-text-muted italic">pago único</span>
            </div>
        </div>

        <p class="mt-4 text-[13px] text-text-muted leading-relaxed opacity-80">
            {description}
        </p>
    </div>

    <div class="w-full h-px bg-linear-to-r from-transparent via-white/10 to-transparent mb-6"></div>

    <ul class="mb-8 flex flex-1 flex-col gap-3.5">
        {features.map((feature) => (
            <li class="flex items-start gap-3 text-[13px] text-gray-400 group-hover:text-gray-200 group-active:text-gray-200 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-white/70 group-hover:text-accent group-active:text-accent transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                <span class="leading-snug">{feature}</span>
            </li>
        ))}  
    </ul>

    <a 
        href={whatsappUrl}
        target="_blank" 
        rel="noopener noreferrer"
        class="relative flex h-11 w-full items-center justify-center rounded-xl bg-white/5 border border-white/10 text-white text-xs font-bold transition-all duration-300 
        hover:bg-primary hover:border-primary hover:shadow-lg hover:shadow-primary/20
        active:bg-primary active:scale-95"
    >
        <span class="flex items-center gap-2">
            Solicitar Información
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
        </span>
    </a>
</div>