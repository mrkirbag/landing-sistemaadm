---
import BenefitCard from "@/components/BenefitCard.astro";
---

<section class="snap-start scroll-mt-10 relative flex min-h-screen w-full items-center justify-center px-6 py-12" id="beneficios">
    <div class="mx-auto max-w-7xl w-full">
        
        <div class="mb-10 flex flex-col gap-3 text-center">
            <h2 class="text-2xl font-bold tracking-tight text-white md:text-3xl">
                Potencia tu eficiencia operativa
            </h2>
        </div>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-12 md:grid-rows-2 max-h-se touch-manipulation">
            
            <BenefitCard 
                title="Acceso Multiplataforma" 
                description="Gestiona tu empresa desde cualquier lugar."
                class="md:col-span-7 lg:col-span-8 overflow-hidden active:scale-[0.99] transition-transform"
            >
                <div class="relative flex h-full items-end justify-center">
                    <div class="relative z-10 w-64 sm:w-80 lg:w-96 transition-all duration-700 ease-out group-hover:scale-[1.02] group-active:scale-[1.02]">
                        <img 
                            class="w-full opacity-60 group-hover:opacity-100 group-active:opacity-100 transition-all duration-700 shadow-2xl" 
                            src="/img/mockup1.png" 
                            alt="Laptop" 
                        />
                    </div>
                    
                    <div class="absolute z-20 bottom-4 left-1/2 -translate-x-1/2 w-40 opacity-90 sm:w-48 lg:left-10 lg:translate-x-0 lg:bottom-10 lg:w-52 transition-all duration-500 group-hover:-translate-y-6 group-hover:-rotate-2 group-hover:opacity-100 group-active:-translate-y-6 group-active:-rotate-2 group-active:opacity-100">
                        <img 
                            class="w-full rounded-xl border border-white/10 bg-card-dark shadow-[0_20px_50px_rgba(0,0,0,0.5)]" 
                            src="/img/mockup3.png" 
                            alt="Tablet" 
                        />
                    </div>

                    <div class="absolute z-30 bottom-2 right-1/4 translate-x-1/2 w-16 opacity-90 grayscale-75 sm:w-20 lg:right-14 lg:translate-x-0 lg:bottom-6 lg:w-24 transition-all duration-500 group-hover:scale-110 group-hover:rotate-[4deg] group-hover:-translate-y-2 group-hover:opacity-100 group-hover:grayscale-0 group-active:scale-110 group-active:rotate-[4deg] group-active:-translate-y-2 group-active:opacity-100 group-active:grayscale-0">
                        <img 
                            class="w-full rounded-lg border border-white/10 bg-card-dark shadow-2xl" 
                            src="/img/mockup2.png" 
                            alt="Phone" 
                        />
                    </div>
                </div>
            </BenefitCard>

            <BenefitCard 
                title="Control de tu negocio en tiempo real" 
                description="Visualiza cada transacción y estadística."
                class="md:col-span-5 lg:col-span-4 active:scale-[0.99] transition-transform"
            >
                <div class="flex items-center justify-center mt-2">
                    <img class="h-full w-full object-cover rounded-xl opacity-60 group-hover:scale-105 group-hover:opacity-100 group-active:scale-105 group-active:opacity-100 transition-all duration-500" src="/img/dashboard.png" alt="Sales dashboard" />
                </div>
            </BenefitCard>

            <BenefitCard 
                title="Inventario Inteligente" 
                description="Mantén al día toda tu mercancía."
                class="md:col-span-5 lg:col-span-4 active:scale-[0.99] transition-transform"
            >
                <div class="flex items-center justify-center mt-2">
                    <img class="h-full w-full object-cover rounded-xl opacity-60 group-hover:scale-105 group-hover:opacity-100 group-active:scale-105 group-active:opacity-100 transition-all duration-500" src="/img/inventario.png" alt="Inventario de Productos" />
                </div>
            </BenefitCard>

            <BenefitCard 
                title="Finanzas y Créditos vigilados" 
                description="Despídete de las deudas olvidadas."
                class="md:col-span-7 lg:col-span-8 active:scale-[0.99] transition-transform"
            >
                <div class="relative mt-auto flex flex-col items-center justify-center p-4 overflow-hidden">
                    <div class="grid grid-cols-1 grid-rows-1 w-full max-w-64 md:flex md:max-w-full md:items-center md:justify-center">
                        
                        <div class="col-start-1 row-start-1 z-30 ease-out 
                                    opacity-100 group-hover:opacity-0 group-hover:scale-95 group-active:opacity-0 group-active:scale-95 transition-all duration-500
                                    md:relative md:opacity-60 md:group-hover:opacity-100 md:group-active:opacity-100 md:group-hover:z-30 md:group-active:z-30 md:group-hover:scale-105 md:group-active:scale-105 md:group-hover:-rotate-3 md:group-active:-rotate-3 md:-mr-10 lg:-mr-12">
                            <div class="aspect-16/10 w-full md:w-72 lg:w-80 flex items-center justify-center">
                                <img 
                                    class="max-h-full max-w-full rounded-2xl border border-white/10 object-contain shadow-2xl" 
                                    src="/img/creditos.png" 
                                    alt="Panel Créditos" 
                                />
                            </div>
                        </div>
                        
                        <div class="col-start-1 row-start-1 z-20 transition-all duration-500 ease-out
                                    opacity-0 group-hover:opacity-100 group-hover:scale-105 group-active:opacity-100 group-active:scale-105 md:opacity-100
                                    md:relative md:z-100 md:group-hover:z-0 md:group-active:z-0 md:mt-12 md:-ml-10 md:group-hover:rotate-3 md:group-active:rotate-3 md:group-hover:-translate-y-2 md:group-active:-translate-y-2 md:group-hover:opacity-60 md:group-active:opacity-60">
                            <div class="aspect-16/10 w-full md:w-72 lg:w-80 flex items-center justify-center">
                                <img 
                                    class="max-h-full max-w-full rounded-2xl border border-white/20 object-contain shadow-[0_20px_50px_rgba(0,0,0,0.5)]" 
                                    src="/img/reportes.png" 
                                    alt="Panel Reportes" 
                                />
                            </div>
                        </div>

                    </div>
                </div>
            </BenefitCard>

        </div>
    </div>
</section>