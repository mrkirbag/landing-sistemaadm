---
const phoneNumber = "584247217176";
const demoMessage = encodeURIComponent("Hola! 👋 Me gustaría solicitar una demostración del sistema administrativo.");
const whatsappDemoUrl = `https://wa.me/${phoneNumber}?text=${demoMessage}`;
---

<section class="relative h-screen flex items-center justify-center overflow-hidden snap-start" id="hero">
    
    <div class="absolute inset-0 z-0 bg-[radial-gradient(ellipse_at_top,var(--color-accent)_0%,transparent_70%)] opacity-15"></div> 

    <div class="mx-auto max-w-7xl px-6 relative z-10 mt-10">
        <div class="text-center">

            <h1 class="text-4xl lg:text-6xl font-extrabold tracking-tighter text-custom-gray mb-8 leading-[1.1] block">
                Tus finanzas bajo control con <br />
                <span class="text-transparent bg-clip-text bg-linear-to-br from-secondary via-accent to-custom-gray drop-shadow-[0_0_20px_rgba(112,89,227,0.3)]">
                    Precisión Absoluta
                </span>
            </h1>

            <p class="mx-auto max-w-2xl text-lg md:text-xl text-text-muted/80 mb-12 leading-relaxed">
                La plataforma definitiva para gestionar inventarios, reportes e ingresos en tiempo real
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-5">

                <a class="glow-effect group h-14 w-full sm:w-auto px-10 rounded-xl bg-acc  ent text-custom-gray font-bold text-lg hover:scale-105 transition-all flex items-center justify-center gap-2 cursor-pointer"
                href="#planes" 
                >
                    Empieza ahora
                    <svg 
                        xmlns="http://www.w3.org/2000/svg" 
                        fill="none" 
                        viewBox="0 0 24 24" 
                        stroke-width="2.5" 
                        stroke="currentColor" 
                        class="w-5 h-5 transition-transform group-hover:translate-x-1"
                    >
                        <path 
                        stroke-linecap="round" 
                        stroke-linejoin="round" 
                        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" 
                        />
                    </svg>
                </a>
                
                <a class="h-14 w-full sm:w-auto px-10 rounded-xl border flex items-center justify-center border-white/10 bg-white/5 font-bold text-white hover:bg-white/10 transition-all backdrop-blur-md cursor-pointer"
                href={whatsappDemoUrl}
                target="_blank"
                rel="noopener noreferrer"   
                >
                    Solicita tu demo
                </a>
            </div>
        </div>
    </div>
</section>